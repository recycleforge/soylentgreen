          { "month": "10", "range": { "start": 1, "end": 31 } },
          { "month": "11", "range": { "start": 1, "end": 30 } },
          { "month": "12", "range": { "start": 1, "end": 31 } }
        ]
      }
    },
    "indexing_notes": {
